generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  email     String   @unique
  avatar    String?

  articles  Article[]
  media     Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id           String   @id @default(cuid())

  title        String
  slug         String   @unique

  body         Json
  excerpt      String

  coverImage   String?

  published    Boolean  @default(false)
  publishedAt  DateTime?

  readCount    Int      @default(0)

  authorId     String
  author       User     @relation(fields: [authorId], references: [id])

  deletedAt    DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tags         ArticleTag[]
}
model Tag {
  id       String @id @default(cuid())
  name     String @unique

  articles ArticleTag[]
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}
model Media {
  id        String   @id @default(cuid())

  url       String
  filename  String

  mimeType  String
  sizeBytes Int

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}